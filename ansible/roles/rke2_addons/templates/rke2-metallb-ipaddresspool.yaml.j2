apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: {{ rke2_metallb_ipaddress_pool_name }}
  namespace: {{ rke2_metallb_namespace }}
spec:
  addresses:
{% for address in rke2_metallb_addresses %}
    - "{{ address }}"
{% endfor %}
  autoAssign: {{ rke2_metallb_auto_assign | lower }}
  avoidBuggyIPs: {{ rke2_metallb_avoid_buggy_ips | lower }}
