apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: {{ rke2_metallb_l2advertisement_name }}
  namespace: {{ rke2_metallb_namespace }}
spec:
  ipAddressPools:
    - "{{ rke2_metallb_ipaddress_pool_name }}"
{% if rke2_metallb_l2_interfaces | length > 0 %}
  interfaces:
{% for interface in rke2_metallb_l2_interfaces %}
    - "{{ interface }}"
{% endfor %}
{% endif %}
